{
  "expo": {
    "name": "app",
    "slug": "app",
    "version": "1.0.0",
    "scheme": "disco101",
    "orientation": "portrait",
    "icon": "./assets/images/disco-ball.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/disco-ball.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F2"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/disco-ball.png",
        "backgroundColor": "#F7F5F2"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.tommi07051967.app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "80d75125-fe3d-46f3-aaa8-c7f157e92a6c"
      }
    }
  }
}
